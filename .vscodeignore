# The extension ships ONLY the production bundle (dist/) plus README /
# CHANGELOG / LICENSE / media. Everything below is dev, build, or internal
# and is never packaged into the VSIX.

# ── Source & build inputs (we ship dist/ only) ──
src/**
test/**
out/**
node_modules/**

# ── Tooling / config ──
.vscode/**
.vscode-test/**
.vscode-test.mjs
esbuild.js
tsconfig.json
.eslintrc.json
.c8rc.json
.gitignore
.vscodeignore

# ── QA / coverage / CI artifacts ──
coverage/**
.github/**

# ── Dev-only assets & scripts (the .png/.md they PRODUCE are shipped) ──
samples/**
media/**/*.mjs
media/*.mjs
scripts/**

# ── Repo doc not needed inside the VSIX ──
PUBLISHING.md

# ── Local-only internal working docs (strategy / mining / growth /
#    build reports / vsix archive) — consolidated under _internal/. ──
_internal/**
STRUCTURE.md

# ── Misc ──
**/*.map
**/*.ts
**/.DS_Store
**/tsconfig.tsbuildinfo
