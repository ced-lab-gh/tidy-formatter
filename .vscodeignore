# Source & build inputs (we ship dist/ only)
src/**
test/**
out/**
node_modules/**

# Tooling / config
.vscode/**
.vscode-test/**
.vscode-test.mjs
esbuild.js
tsconfig.json
.eslintrc.json
.gitignore
.vscodeignore

# Project research artifacts (not shipped)
samples/**
data/**
spec.json
SPEC.md
docs/**
MINING.md
BUILD_REPORT.md
PUBLISHING.md

# QA / coverage / CI artifacts (not shipped)
coverage/**
.c8rc.json
.github/**

# Media generator scripts (dev-only helpers; the .png/.md they produce ARE shipped)
# Only the *.mjs generators are excluded — media/icon.png and media/walkthrough/*.{md,png} ship.
media/**/*.mjs
media/*.mjs

# Build / CI helper scripts (dev-only; generate assets or gate releases, never run at runtime).
# The assets they produce (media/before-after/*.png) ARE shipped; the generators are not.
scripts/**
ROADMAP.md
RELEASE_PLAN.md
PLAN_RESUME.md

# Misc
**/*.map
**/*.ts
**/.DS_Store
**/tsconfig.tsbuildinfo

# GTM / marketing assets (internal, not shipped)
gtm/**
